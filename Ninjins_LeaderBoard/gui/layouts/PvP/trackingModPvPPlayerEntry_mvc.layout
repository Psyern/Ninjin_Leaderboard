     position 0 0
     size 1 1
     valign center_ref
     hexactpos 0
     vexactpos 0
     hexactsize 1
     vexactsize 0
     priority 100
     style DayZDefaultPanel
    }
    PanelWidgetClass player_border_right {
     visible 1
     ignorepointer 1
     color 0.9 0.2 0.2 0.4
     size 1 1
     halign right_ref
     valign center_ref
     hexactpos 0
     vexactpos 0
     hexactsize 1
     vexactsize 0
     priority 100
     style DayZDefaultPanel
    }
    PanelWidgetClass player_online_indicator {
     visible 1
     ignorepointer 1
     position 0 0
     size 0.005 1
     valign center_ref
     hexactpos 0
     vexactpos 0
     hexactsize 0
     priority 50
     style rover_sim_colorable
    }
    ImageWidgetClass Survivor_Female {
     visible 1
     ignorepointer 1
     color 1 1 1 1
     position 0.005 0
     size 40 40
     valign center_ref
     hexactpos 0
     vexactpos 0
     hexactsize 1
     vexactsize 1
     priority 50
     image0 ""
     mode blend
     "src alpha" 1
     "clamp mode" clamp
     "stretch mode" stretch_w_h
     "flip v" 0
    }
    TextWidgetClass player_position {
     ignorepointer 1
     color 1 1 1 1
     position 0.08 0
     size 0.05 1
     valign center_ref
     hexactpos 0
     vexactpos 0
     hexactsize 0
     scriptclass "ViewBinding"
     font "gui/fonts/metronbook16"
     "text halign" center
     "text valign" center
     {
      ScriptParamsClass {
       Binding_Name "PlayerPosition"
      }
     }
    }
    TextWidgetClass player_name {
     ignorepointer 1
     color 1 1 1 1
     position 0.13 0
     size 0.2 1
