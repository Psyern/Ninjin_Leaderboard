GridSpacerWidgetClass TrackingModPvPPlayerEntry {
 ignorepointer 1
 position 0 0
 size 0.98 1
 halign center_ref
 valign top_ref
 hexactpos 0
 vexactpos 0
 hexactsize 0
 priority 1
 scriptclass "TrackingModPvPPlayerEntryController"
 style Empty
 "Size To Content H" 0
 "Size To Content V" 1
 content_halign center
 Columns 1
 Rows 1
 {
  PanelWidgetClass player_header_panel {
   visible 1
   ignorepointer 1
   color 0.18 0.18 0.18 0.95
   size 1 45
   halign center_ref
   valign center_ref
   hexactpos 0
   vexactpos 0
   hexactsize 0
   vexactsize 1
   style blank
   {
    PanelWidgetClass player_header_background {
     visible 1
     ignorepointer 1
     color 0.18 0.18 0.18 0.95
     size 1 1
     halign center_ref
     valign center_ref
     hexactpos 0
     vexactpos 0
     hexactsize 0
     style DayZDefaultPanel
    }
    PanelWidgetClass player_border_top {
     visible 1
     ignorepointer 1
     color 0.9 0.2 0.2 0.4
     position 0 0
     size 1 1
     halign center_ref
     hexactpos 0
     vexactpos 0
     hexactsize 0
     vexactsize 1
     priority 100
     style DayZDefaultPanel
    }
    PanelWidgetClass player_border_bottom {
     visible 1
