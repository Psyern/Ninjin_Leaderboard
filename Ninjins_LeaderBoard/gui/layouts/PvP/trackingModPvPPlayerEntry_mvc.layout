    TextWidgetClass player_kd_ratio {
     ignorepointer 1
     color 0.569 0.275 1.0 1
     position 0.66 0
     size 0.08 1
     valign center_ref
     hexactpos 0
     vexactpos 0
     hexactsize 0
     scriptclass "ViewBinding"
     font "gui/fonts/metronbook16"
     "text halign" right
     "text valign" center
     {
      ScriptParamsClass {
       Binding_Name "KDRatio"
      }
     }
    }
    ButtonWidgetClass claim_reward_button {
     visible 0
     clipchildren 0
     ignorepointer 0
     color 0.569 0.275 1 0.8
     position 0.75 0
     size 0.15 1
     halign left_ref
     valign center_ref
     hexactpos 0
     vexactpos 0
     hexactsize 0
     scriptclass "ViewBinding"
     style Default
     {
      ScriptParamsClass {
       Relay_Command "OnClaimRewardButtonClick"
      }
      TextWidgetClass claim_reward_text {
       ignorepointer 1
       color 1 1 1 1
       position 0 0
       size 1 1
       halign center_ref
       valign center_ref
